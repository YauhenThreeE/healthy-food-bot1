BOT_TOKEN=
# Советы /tip: Ollama (локальный, OpenAI-совместимый API)
# Ключ — любая непустая строка (Ollama не проверяет)
GROQ_API_KEY=ollama
GROQ_MODEL=llama3
# Ollama слушает на localhost:11434, /v1 — OpenAI-совместимый endpoint
GROQ_BASE_URL=http://localhost:11434/v1
# Опционально: если не задан GROQ_API_KEY, используется OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Empty = SQLite file in ./data/healthy_food.db
# Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=
# Set to true to log SQL
SQL_ECHO=
