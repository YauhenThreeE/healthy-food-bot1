BOT_TOKEN=
# Советы /tip: приоритет у Groq (OpenAI-совместимый API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Необязательно, по умолчанию https://api.groq.com/openai/v1
GROQ_BASE_URL=
# Опционально: если не задан GROQ_API_KEY, используется OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Empty = SQLite file in ./data/healthy_food.db
# Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=
# Set to true to log SQL
SQL_ECHO=
